# Backend environment variables (server.js)

PORT=3001
HADES_BACKEND_PORT=3001

# Tuya
TUYA_DEVICE_ID=
TUYA_DEVICE_KEY=
TUYA_DEVICE_IP=192.168.1.11
TUYA_DEVICE_VERSION=3.3

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/spotify/callback

# AI services
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Optional voice runtime
GOOGLE_APPLICATION_CREDENTIALS=
HADES_WAKE_RUNTIME=auto
HADES_NATIVE_BRIDGE_VOICE=0

# Optional debug ports
HADES_REMOTE_DEBUG_PORT=9222
HADES_AUTH_DEBUG_PORT=9333

# Optional overrides
# HADES_SCHEDULE_DB_PATH=./hades-schedule-db.json
# HADES_BACKEND_BASE=http://127.0.0.1:3001
# HADES_CHATGPT_URL=https://chatgpt.com/
# HADES_USE_ELECTRON=true
